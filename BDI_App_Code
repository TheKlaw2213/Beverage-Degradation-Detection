<script>
const form = document.getElementById('form');
const btn = document.getElementById('submit');
const err = document.getElementById('err');
const result = document.getElementById('result');

const tabUpload = document.getElementById('tab-upload');
const tabCamera = document.getElementById('tab-camera');
const paneUpload = document.getElementById('pane-upload');
const paneCamera = document.getElementById('pane-camera');

const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const snapBtn = document.getElementById('snap');
const retakeBtn = document.getElementById('retake');
const fileInput = document.getElementById('image');

let mode = 'upload';      // 'upload' | 'camera'
let stream = null;
let capturedBlob = null;  // set after camera capture

async function startCamera() {
  if (stream) return;
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment' }, audio: false
    });
    video.srcObject = stream;
  } catch (e) {
    err.textContent = 'Camera unavailable: ' + e.message;
    err.classList.add('show');
  }
}
function stopCamera() {
  if (stream) {
    stream.getTracks().forEach(t => t.stop());
    stream = null;
    video.srcObject = null;
  }
}

tabUpload.addEventListener('click', () => {
  mode = 'upload';
  tabUpload.classList.add('active');
  tabCamera.classList.remove('active');
  paneUpload.classList.remove('hidden');
  paneCamera.classList.add('hidden');
  stopCamera();
});
tabCamera.addEventListener('click', () => {
  mode = 'camera';
  tabCamera.classList.add('active');
  tabUpload.classList.remove('active');
  paneCamera.classList.remove('hidden');
  paneUpload.classList.add('hidden');
  // reset capture state
  capturedBlob = null;
  canvas.classList.add('hidden');
  video.classList.remove('hidden');
  snapBtn.classList.remove('hidden');
  retakeBtn.classList.add('hidden');
  startCamera();
});

snapBtn.addEventListener('click', () => {
  if (!stream) return;
  const w = video.videoWidth, h = video.videoHeight;
  canvas.width = w; canvas.height = h;
  canvas.getContext('2d').drawImage(video, 0, 0, w, h);
  canvas.classList.remove('hidden');
  video.classList.add('hidden');
  snapBtn.classList.add('hidden');
  retakeBtn.classList.remove('hidden');
  canvas.toBlob((blob) => { capturedBlob = blob; }, 'image/jpeg', 0.92);
});
document.getElementById('stats-btn').addEventListener('click', () => {
  const meta = document.getElementById('meta');
  const btn = document.getElementById('stats-btn');
  const showing = meta.classList.toggle('show');
  btn.textContent = showing ? 'Hide statistics' : 'View statistics';
});

retakeBtn.addEventListener('click', () => {
  capturedBlob = null;
  canvas.classList.add('hidden');
  video.classList.remove('hidden');
  snapBtn.classList.remove('hidden');
  retakeBtn.classList.add('hidden');
});

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  err.textContent = ''; err.classList.remove('show');

  let blob = null, previewUrl = null;
  if (mode === 'upload') {
    const f = fileInput.files[0];
    if (!f) { err.textContent = 'Please choose a photo.'; err.classList.add('show'); return; }
    blob = f;
    previewUrl = URL.createObjectURL(f);
  } else {
    if (!capturedBlob) { err.textContent = 'Please capture a photo first.'; err.classList.add('show'); return; }
    blob = capturedBlob;
    previewUrl = URL.createObjectURL(capturedBlob);
  }

  document.getElementById('uploaded').src = previewUrl;
  const drink = document.getElementById('drink').value;

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Analyzing…';

  try {
    const fd = new FormData();
    fd.append('image', blob, 'capture.jpg');
    fd.append('drink', drink);
    const res = await fetch('/analyze', { method: 'POST', body: fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Request failed');

    document.getElementById('bdi').textContent = data.bdi;
    document.getElementById('drink-out').textContent =
      form.querySelector('#drink option:checked').textContent;
    document.getElementById('file-out').textContent = data.matched_file;
    document.getElementById('score-out').textContent =
      data.similarity_score.toFixed(4);
    // reset stats panel to hidden on each new analysis
    document.getElementById('meta').classList.remove('show');
    document.getElementById('stats-btn').textContent = 'View statistics';
    result.classList.add('show');
  } catch (e) {
    err.textContent = e.message;
    err.classList.add('show');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Analyze';
  }
});
</script>
