import re
import cv2
import numpy as np
from flask import Flask, request, jsonify, render_template_string, send_from_directory

app = Flask(__name__)

IMAGES_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "images")

# Dropdown drinks: display label -> filename prefix in /images
DRINKS = {
    "water":       "Water",
    "cokezero":    "Coke Zero Bottle",
    "cocacola":    "Coke Classic Can",
    "cocacolab":   "Coke Classic Bottle",
    "orangesoda":  "Sunkist Orange Soda",
    "applejuice":  "Snapple Apple Juice",
    "gatorade":    "Gatorade Glacier Freeze",
}

BDI_REGEX = re.compile(r"\|BDI_(\d+)\|")


def compute_hist(img_path):
    """Compute a normalized 3D HSV color histogram for an image."""
    img = cv2.imread(img_path)
    if img is None:
        return None
    img = cv2.resize(img, (256, 256))
    hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
    hist = cv2.calcHist([hsv], [0, 1, 2], None, [8, 8, 8],
                        [0, 180, 0, 256, 0, 256])
    cv2.normalize(hist, hist)
    return hist.flatten()


def compute_hist_from_bytes(data):
    """Compute histogram directly from uploaded bytes."""
    arr = np.frombuffer(data, np.uint8)
    img = cv2.imdecode(arr, cv2.IMREAD_COLOR)
    if img is None:
        return None
    img = cv2.resize(img, (256, 256))
    hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
    hist = cv2.calcHist([hsv], [0, 1, 2], None, [8, 8, 8],
                        [0, 180, 0, 256, 0, 256])
    cv2.normalize(hist, hist)
    return hist.flatten()


# Scan reference images on startup: filename -> (bdi, histogram)
REFERENCE = {}


def load_references():
    if not os.path.isdir(IMAGES_DIR):
        print(f"[warn] images dir not found: {IMAGES_DIR}")
        return
    for fname in sorted(os.listdir(IMAGES_DIR)):
        if fname.startswith("."):
            continue
        if not fname.lower().endswith((".jpg", ".jpeg", ".png")):
            continue
        m = BDI_REGEX.search(fname)
        if not m:
            # skip files that don't carry a BDI tag (e.g. open-container refs)
            continue
        bdi = int(m.group(1))
        hist = compute_hist(os.path.join(IMAGES_DIR, fname))
        if hist is None:
            continue
        REFERENCE[fname] = (bdi, hist)
    print(f"[info] loaded {len(REFERENCE)} reference images")


