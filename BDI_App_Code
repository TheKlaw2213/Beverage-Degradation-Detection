@app.route("/")
def index():
    return render_template_string(HTML, drinks=DRINKS)


@app.route("/images/<path:filename>")
def images(filename):
    return send_from_directory(IMAGES_DIR, filename)


@app.route("/analyze", methods=["POST"])
def analyze():
    drink = request.form.get("drink", "").strip()
    file = request.files.get("image")
    if not drink or drink not in DRINKS:
        return jsonify({"error": "Invalid or missing drink"}), 400
    if not file:
        return jsonify({"error": "Missing image"}), 400

    query_hist = compute_hist_from_bytes(file.read())
    if query_hist is None:
        return jsonify({"error": "Could not decode uploaded image"}), 400
    qh = query_hist.astype("float32")

    # First, sanity-check that this photo looks like *any* drink we know
    # by comparing against every reference. If even the best overall match
    # is poor, reject it as "not a drink".
    global_best = -1.0
    for fn, (bdi, h) in REFERENCE.items():
        s = float(cv2.compareHist(qh, h.astype("float32"), cv2.HISTCMP_CORREL))
        if s > global_best:
            global_best = s

    NOT_A_DRINK_THRESHOLD = 0.35
    if global_best < NOT_A_DRINK_THRESHOLD:
        return jsonify({
            "error": "That photo doesn't look like a drink. Please upload a "
                     "photo of your beverage."
        }), 400

    # Filter references to those matching this drink's prefix
    candidates = [(fn, bdi, h) for fn, (bdi, h) in REFERENCE.items()
                  if fn.startswith(drink)]
    if not candidates:
        return jsonify({"error": f"No reference images for {drink}"}), 404

    best_file, best_bdi, best_score = None, None, -1.0
    for fn, bdi, h in candidates:
        score = float(cv2.compareHist(qh, h.astype("float32"),
                                      cv2.HISTCMP_CORREL))
        if score > best_score:
            best_score = score
            best_file = fn
            best_bdi = bdi

    return jsonify({
        "bdi": best_bdi,
        "matched_file": best_file,
        "similarity_score": best_score,
    })


# Load reference histograms on import so it works under gunicorn too.
load_references()

if __name__ == "__main__":
    app.run(host="127.0.0.1", port=5000, debug=False)
